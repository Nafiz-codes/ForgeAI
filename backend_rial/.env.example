# ─────────────────────────────────────────────────────────────
# ForgeAI Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Google Gemma API key (from Google AI Studio — aistudio.google.com)
# The AI engineer's client reads GEMMA_API_KEY.
GEMMA_API_KEY=your_google_ai_studio_key_here

# Frontend URL for CORS — leave blank locally, set to Vercel URL in production
# FRONTEND_URL=https://your-app.vercel.app
