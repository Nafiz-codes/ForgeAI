# ─────────────────────────────────────────────────────────────
# ForgeAI Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Which AI backend to use: "openai" (default) or "gemini"
AI_BACKEND=openai

# OpenAI settings (required when AI_BACKEND=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Gemini settings (required when AI_BACKEND=gemini)
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemma-3-27b-it

# Frontend URL (for CORS — set to your Vercel domain in production)
# FRONTEND_URL=https://your-app.vercel.app
