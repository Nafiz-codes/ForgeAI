# ─────────────────────────────────────────────────────────────
# ForgeAI Backend — Production Environment Variables
# Copy this to .env and fill in your values.
# On Railway: set these in the Railway dashboard → Variables tab.
# ─────────────────────────────────────────────────────────────

# Google AI Studio API key for Gemma
# Get yours at https://aistudio.google.com/
GEMMA_API_KEY=your_google_ai_studio_key_here

# Your Vercel frontend URL (set AFTER you've deployed to Vercel)
# This is added to the CORS allowed origins in main.py
FRONTEND_URL=https://your-forgeai-app.vercel.app

# Railway automatically injects PORT — do not set this manually.
# PORT=8000
